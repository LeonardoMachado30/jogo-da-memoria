FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json .npmrc ./

# quasar prepare (postinstall) exige quasar.config.ts e demais arquivos do projeto
RUN npm ci --ignore-scripts

EXPOSE 8080

ENTRYPOINT ["sh", "-c", "if [ ! -d node_modules/@quasar/app-vite ]; then npm ci --ignore-scripts; fi && npx quasar prepare && exec npm run dev"]
